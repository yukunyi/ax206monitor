{
  "name": "mini",
  "width": 480,
  "height": 320,
  "layout_padding": 2,
  "default_font": "DejaVu Sans Mono",
  "default_font_size": 15,
  "default_color": "#f8fafc",
  "default_background": "#0b1220",
  "level_colors": [
    "#22c55e",
    "#eab308",
    "#f97316",
    "#ef4444"
  ],
  "default_thresholds": [
    25,
    50,
    75,
    100
  ],
  "output_types": ["memimg"],
  "refresh_interval": 1000,
  "collect_warn_ms": 100,
  "render_wait_max_ms": 300,
  "history_size": 150,
  "custom_monitors": [],
  "items": [
